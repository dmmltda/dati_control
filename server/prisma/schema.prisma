generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model companies {
  id                              String               @id
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime
  CNPJ_da_empresa                 String?              @unique
  Cidade                          String?
  Data_Interesse                  DateTime?
  Data_de_churn                   DateTime?
  Data_de_follow_up               DateTime?
  Data_in_cio_onboarding          DateTime?            @map("Data_início_onboarding")
  Data_t_rmino_onboarding         DateTime?            @map("Data_término_onboarding")
  Dores_Gargalos                  String?
  ERP                             String?
  Estado                          String?
  Expectativa_da_DATI             String?
  Fechamento_onboarding__Sim_N_o_ String?              @map("Fechamento_onboarding_(Sim/Não)")
  Health_Score                    String?
  Hor_rio_de_follow_up            String?              @map("Horário_de_follow_up")
  In_cio_com_CS                   DateTime?            @map("Início_com_CS")
  Lead                            String?
  Modo_da_empresa                 String?
  Motivo_do_churn                 String?
  Nome_da_empresa                 String
  Nome_do_CS                      String?
  Nome_do_usu_rio                 String?              @map("Nome_do_usuário")
  Principal_Objetivo              String?
  Qual___M_dulo___Lotus_          String?              @map("Qual?_(Módulo_/_Lotus)")
  Segmento_da_empresa             String?
  Situa__o_da_reuni_o             String?              @map("Situação_da_reunião")
  Status                          String?
  Sucesso_Extraordin_rio          String?              @map("Sucesso_Extraordinário")
  Tem_algum_comex_                String?              @map("Tem_algum_comex?")
  Tipo_de_empresa                 String?
  Usu_rio_Dati__Sim_N_o_          String?              @map("Usuário_Dati_(Sim/Não)")
  decisor_                        String?              @map("É_decisor?")
  NPS                             String?
  Qual_ERP_                       String?              @map("Qual_ERP?")
  Site                            String?
  company_dashboards              company_dashboards[]
  company_followups               company_followups[]
  company_meetings                company_meetings[]
  company_notes                   company_notes[]
  company_nps                     company_nps[]
  company_products                company_products[]
  company_tickets                 company_tickets[]
  contacts                        contacts[]
  test_logs                       test_logs[]
}

model company_dashboards {
  id           String    @id
  companyId    String
  Data         DateTime?
  Destinatario String?
  Link         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  companies    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_followups {
  id                   String    @id
  companyId            String
  Data_inclusao        DateTime? @default(now())
  Conteudo             String?
  Usuario              String?
  Area                 String?
  Data_proximo_contato DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  companies            companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_meetings {
  id            String    @id
  companyId     String
  Data_reuniao  DateTime?
  Participantes String?
  Temperatura   String?
  Link_gravacao String?
  Observacoes   String?
  Tipo_reuniao  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  companies     companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_notes {
  id        String    @id
  companyId String
  Data      DateTime? @default(now())
  Conteudo  String?
  Autor     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  companies companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_nps {
  id           String    @id
  companyId    String
  Data         DateTime?
  Destinatario String?
  Formulario   String?
  Score        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  companies    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_products {
  id                      String              @id
  companyId               String
  Produto_DATI            String
  Proposta_comercial      String?
  Contrato                String?
  Data_do_contrato        DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  Contrato_nome           String?
  Proposta_nome           String?
  Valor_minimo            Decimal?            @db.Decimal(15, 2)
  Valor_usuario_adicional Decimal?            @db.Decimal(15, 2)
  Tipo_cobranca           String?
  Valor_unitario          Decimal?            @db.Decimal(15, 2)
  Valor_total             Decimal?            @db.Decimal(15, 2)
  Cobranca_setup          String?
  Qtd_usuarios            String?
  Total_horas_hd          Int?
  Valor_adic_hd           Decimal?            @db.Decimal(15, 2)
  Valor_setup             Decimal?            @db.Decimal(15, 2)
  companies               companies           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product_historico       product_historico[]
}

model company_tickets {
  id        String    @id
  companyId String
  Data      DateTime?
  Numero    String?
  Resumo    String?
  Autor     String?
  Link      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  companies companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model contacts {
  id                      String    @id
  companyId               String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime
  Cargo_do_contato        String?
  Departamento_do_contato String?
  Email_1                 String?
  LinkedIn                String?
  Nome_do_contato         String?
  WhatsApp                String?
  companies               companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model product_historico {
  id                   String           @id
  productId            String
  Data_faturamento     DateTime?
  Data_pagamento       DateTime?
  Anexo_NF             String?
  Anexo_NF_nome        String?
  Anexo_pagamento      String?
  Anexo_pagamento_nome String?
  Outros_anexos        String?
  Outros_anexos_nome   String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime
  company_products     company_products @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model test_logs {
  id                String    @id
  companyId         String
  Data_teste        DateTime?
  Hora_teste        String?
  Tipo_teste        String?
  M_dulo_teste      String?   @map("Módulo_teste")
  O_que_foi_testado String?
  Quem_foi_testado  String?
  Status_teste      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  companies         companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
