generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model companies {
  id                              String               @id
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime
  CNPJ_da_empresa                 String?              @unique
  Cidade                          String?
  Data_Interesse                  DateTime?
  Data_de_churn                   DateTime?
  Data_de_follow_up               DateTime?
  Data_in_cio_onboarding          DateTime?            @map("Data_início_onboarding")
  Data_t_rmino_onboarding         DateTime?            @map("Data_término_onboarding")
  Dores_Gargalos                  String?
  ERP                             String?
  Estado                          String?
  Expectativa_da_DATI             String?
  Fechamento_onboarding__Sim_N_o_ String?              @map("Fechamento_onboarding_(Sim/Não)")
  Health_Score                    String?
  Hor_rio_de_follow_up            String?              @map("Horário_de_follow_up")
  In_cio_com_CS                   DateTime?            @map("Início_com_CS")
  Lead                            String?
  Modo_da_empresa                 String?
  Motivo_do_churn                 String?
  Nome_da_empresa                 String
  Nome_do_CS                      String?
  Nome_do_usu_rio                 String?              @map("Nome_do_usuário")
  Principal_Objetivo              String?
  Qual___M_dulo___Lotus_          String?              @map("Qual?_(Módulo_/_Lotus)")
  Segmento_da_empresa             String?
  Situa__o_da_reuni_o             String?              @map("Situação_da_reunião")
  Status                          String?
  Sucesso_Extraordin_rio          String?              @map("Sucesso_Extraordinário")
  Tem_algum_comex_                String?              @map("Tem_algum_comex?")
  Tipo_de_empresa                 String?
  Usu_rio_Dati__Sim_N_o_          String?              @map("Usuário_Dati_(Sim/Não)")
  decisor_                        String?              @map("É_decisor?")
  NPS                             String?
  Qual_ERP_                       String?              @map("Qual_ERP?")
  Site                            String?

  // ── HIERARQUIA MÃE/FILHA ──────────────────────────────────────────────────
  // "mom"        → empresa mãe (contratante da plataforma = 1 Clerk Organization)
  // "son"        → empresa filha (filial ou cliente gerenciado pela mãe)
  // "standalone" → empresa independente (compatibilidade com dados existentes)
  company_type                    String               @default("standalone")
  mom_id                          String?              // null = é mãe ou standalone
  clerk_org_id                    String?              @unique // ID da Organization no Clerk (só para company_mom)

  // relações de hierarquia (autorreferente)
  company_mom                     companies?           @relation("MomSon", fields: [mom_id], references: [id])
  company_sons                    companies[]          @relation("MomSon")

  // relações existentes
  company_dashboards              company_dashboards[]
  company_followups               company_followups[]
  company_meetings                company_meetings[]
  company_notes                   company_notes[]
  company_nps                     company_nps[]
  company_products                company_products[]
  company_tickets                 company_tickets[]
  contacts                        contacts[]
  test_runs_triggered              test_runs[]      // execuções manuais disparadas pela aba LOG
  activities                      activities[]
  whatsapp_conversations          whatsapp_conversations[]

  // relações de usuários
  user_memberships                user_memberships[]
  user_invites                    user_invites[]
}

model company_dashboards {
  id           String    @id
  companyId    String
  Data         DateTime?
  Destinatario String?
  Link         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  companies    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_followups {
  id                   String    @id
  companyId            String
  Data_inclusao        DateTime? @default(now())
  Conteudo             String?
  Usuario              String?
  Area                 String?
  Data_proximo_contato DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  companies            companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_meetings {
  id            String    @id
  companyId     String
  Data_reuniao  DateTime?
  Participantes String?
  Temperatura   String?
  Link_gravacao String?
  Observacoes   String?
  Tipo_reuniao  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  companies     companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_notes {
  id        String    @id
  companyId String
  Data      DateTime? @default(now())
  Conteudo  String?
  Autor     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  companies companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_nps {
  id           String    @id
  companyId    String
  Data         DateTime?
  Destinatario String?
  Formulario   String?
  Score        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  companies    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model company_products {
  id                      String              @id
  companyId               String
  Produto_DATI            String
  Proposta_comercial      String?
  Contrato                String?
  Data_do_contrato        DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  Contrato_nome           String?
  Proposta_nome           String?
  Valor_minimo            Decimal?            @db.Decimal(15, 2)
  Valor_usuario_adicional Decimal?            @db.Decimal(15, 2)
  Tipo_cobranca           String?
  Valor_unitario          Decimal?            @db.Decimal(15, 2)
  Valor_total             Decimal?            @db.Decimal(15, 2)
  Cobranca_setup          String?
  Qtd_usuarios            String?
  Total_horas_hd          Int?
  Valor_adic_hd           Decimal?            @db.Decimal(15, 2)
  Valor_setup             Decimal?            @db.Decimal(15, 2)
  companies               companies           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product_historico       product_historico[]
}

model company_tickets {
  id        String    @id
  companyId String
  Data      DateTime?
  Numero    String?
  Resumo    String?
  Autor     String?
  Link      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  companies companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model contacts {
  id                      String    @id
  companyId               String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime
  Cargo_do_contato        String?
  Departamento_do_contato String?
  Email_1                 String?
  LinkedIn                String?
  Nome_do_contato         String?
  WhatsApp                String?
  companies               companies @relation(fields: [companyId], references: [id], onDelete: Cascade)
  whatsapp_conversations  whatsapp_conversations[]
}

model product_historico {
  id                   String           @id
  productId            String
  Data_faturamento     DateTime?
  Data_pagamento       DateTime?
  Anexo_NF             String?
  Anexo_NF_nome        String?
  Anexo_pagamento      String?
  Anexo_pagamento_nome String?
  Outros_anexos        String?
  Outros_anexos_nome   String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime
  company_products     company_products @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO DE TESTES — Independente de empresa (sistema)
// ══════════════════════════════════════════════════════════════════════════════

/// Uma execução de suite de testes (pode conter N casos individuais)
model test_runs {
  id              String       @id @default(uuid())
  suite_type      String                          // "UNITÁRIO" | "FUNCIONAL" | "E2E"
  triggered_by    String?                         // user_id Clerk de quem clicou "Rodar Testes"
  triggered_at    DateTime     @default(now())
  environment     String       @default("local")  // "local" | "staging" | "production"
  status          String       @default("running")// "running" | "passed" | "failed" | "error"
  total_tests     Int          @default(0)
  passed_tests    Int          @default(0)
  failed_tests    Int          @default(0)
  error_tests     Int          @default(0)
  duration_ms     Int?                            // duração total em ms
  raw_output      String?                         // JSON bruto do reporter (Vitest/Playwright)
  companies       companies?   @relation(fields: [company_id], references: [id])
  company_id      String?                         // quem disparou (context only, sem cascade)
  test_cases      test_cases[]
}

/// Um caso de teste individual, filho de test_runs
model test_cases {
  id              String     @id @default(uuid())
  run_id          String
  suite_file      String?                         // nome do arquivo (ex: "auth.test.js")
  module          String?                         // módulo testado (ex: "api.js", "config.js")
  test_name       String                          // nome do describe/it
  suite_type      String                          // herda do run
  status          String                          // "PASSOU" | "FALHOU" | "ERRO" | "SKIPADO"
  duration_ms     Int?                            // duração em ms
  error_message   String?                         // mensagem de erro se falhou
  error_stack     String?                         // stack trace
  screenshot_url  String?                         // screenshot (Playwright)
  video_url       String?                         // vídeo (Playwright)
  created_at      DateTime   @default(now())
  test_run        test_runs  @relation(fields: [run_id], references: [id], onDelete: Cascade)
}

/// Configuração de agendamento de testes (global — um registro único)
model test_schedule {
  id                    String   @id @default(uuid())
  enabled               Boolean  @default(false)
  frequency             String   @default("manual")     // "manual" | "diario" | "semanal"
  weekday               Int?                             // 0=domingo … 6=sábado (só para "semanal")
  hour                  Int      @default(2)             // hora UTC de execução (0-23)
  minute                Int      @default(0)             // minuto de execução (0-59)
  run_time              String   @default("02:00")       // legado compatível: HH:MM
  run_unit              Boolean  @default(true)
  run_functional        Boolean  @default(true)
  run_e2e               Boolean  @default(false)
  notify_email          String?                          // email de destino (ex: "eng@dati.com")
  notify_emails         String?                          // legado: CSV de emails
  notify_on_failure_only Boolean @default(true)          // notificar só em falha?
  environment           String   @default("local")
  last_run_at           DateTime?                        // última execução
  next_run_at           DateTime?                        // próxima execução calculada
  updated_by            String?                          // user_id do último master que editou
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO DE IMPORTAÇÃO EM MASSA
// ══════════════════════════════════════════════════════════════════════════════

model import_jobs {
  id               String           @id @default(uuid())
  user_id          String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  status           String           @default("pending")
  total_rows       Int              @default(0)
  valid_rows       Int              @default(0)
  error_rows       Int              @default(0)
  duplicate_rows   Int              @default(0)
  duplicate_action String           @default("ignore")
  filename         String?
  staging          import_staging[]
  logs             import_logs[]
}

model import_staging {
  id                String      @id @default(uuid())
  import_id         String
  row_number        Int
  empresa           String?
  cnpj              String?
  status_empresa    String?
  tipo_empresa      String?
  segmento          String?
  cidade            String?
  estado            String?
  site              String?
  contato_nome      String?
  contato_email     String?
  contato_telefone  String?
  cargo             String?
  departamento      String?
  linkedin          String?
  // Produto DATI
  produto_dati      String?
  tipo_cobranca     String?
  valor_unitario    Decimal?    @db.Decimal(15, 2)
  valor_minimo      Decimal?    @db.Decimal(15, 2)
  cobranca_setup    String?
  valor_setup       Decimal?    @db.Decimal(15, 2)
  qtd_usuarios      String?
  valor_usuario_adic Decimal?   @db.Decimal(15, 2)
  total_horas_hd    Int?
  valor_adic_hd     Decimal?    @db.Decimal(15, 2)
  // Contatos e produtos extras (quando há mais de 1 por empresa)
  contatos_extra_json String?   // JSON array de contatos adicionais
  produtos_extra_json String?   // JSON array de produtos adicionais
  status            String      @default("pending")
  error_message     String?
  import_jobs       import_jobs @relation(fields: [import_id], references: [id], onDelete: Cascade)
}

model import_logs {
  id                String      @id @default(uuid())
  import_id         String
  executed_at       DateTime    @default(now())
  executed_by       String?
  companies_created Int         @default(0)
  contacts_created  Int         @default(0)
  errors            Int         @default(0)
  import_jobs       import_jobs @relation(fields: [import_id], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO DE ATIVIDADES
// Timeline operacional da empresa — registra todas as interações
// ══════════════════════════════════════════════════════════════════════════════

model activities {
  id                              String                           @id @default(uuid())
  company_id                      String?                          // Nullable: permite atividades/tarefas globais sem empresa vinculada
  activity_type                   String                           // ENUM: Comentário | Reunião | Chamados HD | Chamados CS | Ação necessária
  title                           String
  description                     String?
  department                      String?
  created_by_user_id              String?
  created_at                      DateTime                         @default(now())
  updated_at                      DateTime                         @updatedAt
  activity_datetime               DateTime?
  status                          String?
  time_spent_minutes              Int?
  next_step_title                 String?
  next_step_date                  DateTime?
  // ── NOVOS CAMPOS ──
  priority                        String?                          // "baixa" | "média" | "alta" | "urgente"
  reminder_at                     DateTime?
  reminder_email                  Boolean                          @default(false)
  reminder_whatsapp               Boolean                          @default(false)
  reminder_sent                   Boolean                          @default(false)
  google_meet_link                String?
  google_event_id                 String?
  // ── CAMPOS DE NOTIFICAÇÃO ──
  send_invite_email               Boolean                          @default(false)
  invite_sent                     Boolean                          @default(false)
  send_summary_email              Boolean                          @default(false)
  summary_sent                    Boolean                          @default(false)
  recording_url                   String?
  send_recording_email            Boolean                          @default(false)
  recording_sent                  Boolean                          @default(false)
  next_step_reminder_email        Boolean                          @default(false)
  next_step_reminder_sent         Boolean                          @default(false)
  notify_on_assign                Boolean                          @default(false)
  // ── RELAÇÕES ──
  companies                       companies?                       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  activity_assignees              activity_assignees[]
  activity_next_step_responsibles activity_next_step_responsibles[]
  activity_attachments            activity_attachments[]
  activity_mentions               activity_mentions[]
  activity_time_logs              activity_time_logs[]
  notifications                   notifications[]
}

model activity_assignees {
  id          String     @id @default(uuid())
  activity_id String
  user_id     String
  activity    activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
}

model activity_next_step_responsibles {
  id          String     @id @default(uuid())
  activity_id String
  user_id     String
  activity    activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
}

model activity_attachments {
  id          String     @id @default(uuid())
  activity_id String
  file_url    String     // URL pública no Supabase Storage
  file_name   String
  file_type   String     // "document" | "video" | "image" | "meet_recording"
  file_size   Int?       // em bytes
  uploaded_by String?    // user_id (FK users)
  created_at  DateTime   @default(now())
  activity    activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
}

model activity_mentions {
  id          String     @id @default(uuid())
  activity_id String
  user_id     String     // user_id de quem foi mencionado
  activity    activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
}

/// Sessões de tempo registradas na aba Tempo de cada atividade
model activity_time_logs {
  id               String     @id @default(uuid())
  activity_id      String
  started_at       DateTime                       // data e hora de início da sessão
  duration_minutes Int                            // duração em minutos (fechado/fixo)
  subject          String?                        // assunto — editável pelo usuário
  created_by       String?                        // user_id de quem registrou
  created_at       DateTime   @default(now())
  activity         activities @relation(fields: [activity_id], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO DE USUÁRIOS — sincronizado com Clerk
// O id é o Clerk User ID (ex: "user_2abc123...")
// ══════════════════════════════════════════════════════════════════════════════
model users {
  id         String   @id              // Clerk User ID — string literal, não UUID gerado localmente
  nome       String
  email      String   @unique
  avatar     String?                   // Iniciais (ex: "DS") — gerado a partir do nome
  role       String   @default("member") // legado — mantido para compatibilidade
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── TIPO DE USUÁRIO (novo modelo) ─────────────────────────────────────────
  // "master"   → acesso total à company_mom e TODAS as company_sons
  //              pode convidar, editar e remover usuários
  // "standard" → acesso SOMENTE às company_sons vinculadas via user_memberships
  //              permissões (criar/editar/deletar/exportar) definidas pelo master
  user_type  String   @default("standard")

  // ── METADATA ──────────────────────────────────────────────────────────────
  phone      String?                   // telefone/WhatsApp do usuário
  department String?                   // área: "CS" | "Comercial" | "Produto" | "Suporte"
  timezone   String?  @default("America/Sao_Paulo")

  // ── RELAÇÕES ──────────────────────────────────────────────────────────────
  user_memberships         user_memberships[]
  user_feature_permissions user_feature_permissions[]
}

// ══════════════════════════════════════════════════════════════════════════════
// PERMISSÕES DE FUNCIONALIDADE — Controle granular de acesso a módulos
// Gerenciadas pelo master via UI de configurações.
// Master sempre tem acesso total (sem entradas nesta tabela).
// Standard: só acessa o que tiver granted=true aqui.
// ══════════════════════════════════════════════════════════════════════════════
model user_feature_permissions {
  id          String   @id @default(uuid())
  user_id     String
  permission  String   // ex: 'dashboard.view', 'companies.edit_full', 'gabi.view'
  granted     Boolean  @default(true)
  granted_by  String?  // user_id do master que concedeu/revogou
  updated_at  DateTime @updatedAt

  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, permission])
  @@map("user_feature_permissions")
}

// ══════════════════════════════════════════════════════════════════════════════
// VÍNCULO USUÁRIO ↔ EMPRESA FILHA
// Registra quais company_sons o usuário standard pode acessar.
// Para usuários master, o acesso é implícito (não precisa de membership por filha).
// ══════════════════════════════════════════════════════════════════════════════
model user_memberships {
  id          String   @id @default(uuid())
  user_id     String
  company_id  String   // sempre uma company_son (filha)

  // permissões que o master concedeu a este standard nesta filha
  can_create  Boolean  @default(true)   // pode criar registros?
  can_edit    Boolean  @default(true)   // pode editar registros?
  can_delete  Boolean  @default(false)  // pode deletar registros?
  can_export  Boolean  @default(false)  // pode exportar dados?

  invited_by  String?                   // user_id (master) que convidou
  joined_at   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  company     companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([user_id, company_id])
}

// ══════════════════════════════════════════════════════════════════════════════
// CONVITES PENDENTES
// Rastreamento de convites enviados via Clerk Organizations.
// ══════════════════════════════════════════════════════════════════════════════
model user_invites {
  id              String    @id @default(uuid())
  email           String
  company_mom_id  String                        // qual company_mom (org) este convite pertence
  user_type       String    @default("standard") // "master" | "standard"

  // se standard, quais filhas pré-atribuídas ao aceitar o convite?
  companies_json  String?                       // JSON: ["son_id_1", "son_id_2"] — null para master

  clerk_invite_id String?   @unique             // ID do convite no Clerk Organizations
  invited_by      String                        // user_id do master que convidou
  status          String    @default("pending") // "pending" | "accepted" | "expired" | "revoked"

  expires_at      DateTime?
  accepted_at     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         companies @relation(fields: [company_mom_id], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════════════════
// CATÁLOGO DE PRODUTOS DATI — Registro mestre dos produtos comercializados
// Independente das empresas — define quais produtos existem no portfólio DATI
// ══════════════════════════════════════════════════════════════════════════════
model product_catalog {
  id          String   @id @default(uuid())
  nome        String                        // Ex: "DATI Import", "DATI Export", "Smart Read", "Catálogo de Produtos", "Orkestra" (em breve)
  descricao   String?                       // Descrição longa do produto
  categoria   String?                       // Ex: "Importação", "Exportação", "Compliance"
  status      String   @default("Ativo")    // "Ativo" | "Inativo" | "Em desenvolvimento"
  icone       String?                       // Nome do ícone Phosphor. Ex: "ph-cube"
  cor_badge   String?                       // Hex da cor do badge. Ex: "#5b52f6"
  ordem       Int      @default(0)          // Ordem de exibição na listagem
  site_url    String?                       // URL da landing page do produto
  video_url   String?                       // URL do vídeo de apresentação
  beneficios  String?                       // Texto livre — principais benefícios
  publico_alvo String?                      // Público-alvo do produto
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ══════════════════════════════════════════════════════════════════════════════
// AUDIT LOG — Histórico de alterações do sistema
// Registra QUEM fez O QUÊ e QUANDO em cada entidade relevante.
// actor_label é denormalizado no momento da escrita para evitar JOINs e
// preservar o nome mesmo se o usuário for deletado depois.
// ══════════════════════════════════════════════════════════════════════════════
model audit_logs {
  id           String   @id @default(uuid())
  created_at   DateTime @default(now())

  // ── QUEM ──────────────────────────────────────────────────────────────────
  actor_id     String?  // null = plataforma (Journey)
  actor_label  String   // "Daniel Martins" | "Rafa via Daniel Martins" | "Journey"

  // ── O QUÊ ─────────────────────────────────────────────────────────────────
  action       String   // CREATE | UPDATE | DELETE | INVITE | MEMBERSHIP | IMPORT | SYSTEM
  entity_type  String   // company | contact | user | membership | invite | activity | import
  entity_id    String?  // ID do registro afetado (snapshot — pode ser deletado depois)
  entity_name  String?  // nome legível: nome da empresa, email do usuário, etc.

  // ── DESCRIÇÃO ─────────────────────────────────────────────────────────────
  description  String   // "Criou a empresa Acme Ltda" | "Atualizou Status de 'Ativo' para 'Churned'"
  meta         Json?    // { old: {}, new: {}, fields: ["Status", "Health_Score"] }

  // ── CONTEXTO ──────────────────────────────────────────────────────────────
  company_id   String?  // empresa relacionada (usado para filtros por contexto)
  ip_address   String?  // req.ip — rastreabilidade
}

// ─── Gabi AI — Log de consumo da API Gemini ──────────────────────────────────
model gabi_usage_logs {
  id            String   @id @default(uuid())
  user_id       String?                // ID Clerk do usuário que fez a chamada
  input_tokens  Int      @default(0)   // Tokens de entrada (prompt)
  output_tokens Int      @default(0)   // Tokens de saída (resposta)
  cost_usd      Float    @default(0)   // Custo em USD desta chamada
  created_at    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════════════════════
// NOTIFICAÇÕES IN-APP — Sininho do header
// Registra avisos para cada usuário: menções em atividades e próximos passos.
// "read" permite marcar como lida sem deletar o histórico.
// ══════════════════════════════════════════════════════════════════════════════
model notifications {
  id          String      @id @default(uuid())
  user_id     String                            // destinatário (Clerk user_id)
  type        String                            // "mentioned" | "next-step-assigned"
  activity_id String?                           // atividade relacionada (pode ser null)
  title       String                            // ex: "Você foi marcado em uma atividade"
  message     String                            // ex: "Daniel te marcou em: 'Não temos contato' (PRINT MAIS)"
  read        Boolean     @default(false)
  created_at  DateTime    @default(now())
  activity    activities? @relation(fields: [activity_id], references: [id], onDelete: SetNull)

  @@index([user_id, read])
  @@index([created_at])
}

// ─── Configurações Gerais da Plataforma ──────────────────────────────────────
// Chave-valor para armazenar configurações do sistema que precisam persistir
// mesmo sem variáveis de ambiente (ex: GEMINI_API_KEY configurada via UI).
// valores sensíveis (API keys) são armazenados aqui e nunca expostos no front.
model app_settings {
  key        String   @id                      // ex: "gemini_api_key", "gabi_monthly_limit_usd"
  value      String                            // valor em texto
  updated_at DateTime @updatedAt
  updated_by String?                           // user_id do master que alterou

  @@map("app_settings")
}

// ─── E-mail — Deduplicação de envios ─────────────────────────────────────────
// Garante que o mesmo e-mail nunca seja enviado mais de uma vez.
// O UNIQUE em dedup_key é aplicado atomicamente pelo Postgres,
// protegendo contra race conditions e múltiplas instâncias do servidor.
model email_send_log {
  id            String   @id @default(uuid())
  dedup_key     String   @unique           // Chave única de negócio (ex: "lembrete-abc123-2026-03-01")
  recipient     String                     // Destinatário(s) — para auditoria
  subject       String                     // Assunto — para auditoria
  template      String?                    // Nome do template usado (ex: "activityReminder")
  tag           String?                    // Tag livre para logs (ex: "gabi-alert")
  status        String   @default("sent")  // sent | failed | blocked | pending
  resend_id     String?                    // ID retornado pela API Resend
  error_message String?                    // Mensagem de erro se falhou
  sent_at       DateTime @default(now())   // Quando foi enviado

  @@index([sent_at])
  @@index([status])
  @@map("email_send_log")
}

// ══════════════════════════════════════════════════════════════════════════════
// MÓDULO WHATSAPP — Inbox HD + Notificações
// ══════════════════════════════════════════════════════════════════════════════

// ── INBOX HD ──────────────────────────────────────────────────────────────────

model whatsapp_conversations {
  id              String    @id @default(uuid())
  contact_id      String?                         // FK contacts (nullable)
  company_id      String?                         // FK companies (nullable)
  wa_phone_number String                          // número E.164: +5511999999999
  status          String    @default("open")      // "open" | "closed"
  opened_at       DateTime  @default(now())
  closed_at       DateTime?
  assigned_to     String?                         // user_id do agente (Clerk)
  activity_id     String?                         // FK activities (criada ao fechar)

  // Análise Gabi ao fechar
  gabi_temperatura       String?   // "critico"|"negativo"|"neutro"|"positivo"|"encantado"
  gabi_temperatura_score Int?      // 1–5
  gabi_resumo            String?   // resumo gerado pela Gabi
  gabi_acoes_sugeridas   String?   // JSON array de ações sugeridas

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages  whatsapp_messages[]
  contacts  contacts?   @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  companies companies?  @relation(fields: [company_id], references: [id], onDelete: SetNull)
}

model whatsapp_messages {
  id              String   @id @default(uuid())
  conversation_id String
  wa_message_id   String?  @unique             // ID Meta — dedup (Meta reenvia eventos)
  direction       String                        // "inbound" | "outbound"
  content_type    String   @default("text")     // "text" | "image" | "audio" | "document"
  content         String                        // texto ou URL da mídia
  sent_by         String?                       // user_id se agente, null se inbound ou Gabi
  origin          String   @default("agent")    // "agent" | "gabi" | "system" (lembretes)
  status          String   @default("sent")     // "sent" | "delivered" | "read" | "failed"
  created_at      DateTime @default(now())

  conversation whatsapp_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
}

// ── LOG DE CUSTO (padrão gabi_usage_logs) ─────────────────────────────────────

model whatsapp_usage_logs {
  id                    String   @id @default(uuid())
  conversation_id       String?
  company_id            String?
  conversation_category String?  // "service" | "marketing" | "utility" | "notification"
  origin                String?  // "inbox" | "gabi" | "reminder" | "system"
  cost_usd              Float    @default(0)
  created_at            DateTime @default(now())
}
