# ============================================================================
# Variáveis de Ambiente — Testes E2E Playwright
# js/tests/e2e/.env.e2e
# ============================================================================
# NUNCA commitar este arquivo com valores reais de produção.
# Duplicar como .env.e2e.local para valores locais (no .gitignore).
# ============================================================================

# URL base do servidor de testes
BASE_URL=http://localhost:3001

# ─── Usuários de teste (Clerk) ────────────────────────────────────────────────
# Deve existir no org Clerk de desenvolvimento (não produção)
TEST_USER_MASTER_EMAIL=test.master@dati.com.br
TEST_USER_MASTER_PASSWORD=TestMaster@2026!

TEST_USER_STANDARD_EMAIL=test.standard@dati.com.br
TEST_USER_STANDARD_PASSWORD=TestStandard@2026!

# ─── Empresa de seed ──────────────────────────────────────────────────────────
# Criada automaticamente pelo login.setup.js se não existir
TEST_COMPANY_ID=

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Deixe vazio para usar o DATABASE_URL do .env principal
DATABASE_URL_TEST=

# ─── Clerk ────────────────────────────────────────────────────────────────────
# Chave publishable do ambiente de desenvolvimento
# (não é necessária se TEST_MODE=true no servidor)
CLERK_PUBLISHABLE_KEY=
