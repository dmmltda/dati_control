# ──────────────────────────────────────────────────────────────────────────────
# Journey CRM — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# ⚠️  NUNCA commite o .env real — ele está no .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Servidor
PORT=8000
NODE_ENV=development

# ── Banco de Dados (Railway injeta automaticamente em produção) ───────────────
# Em desenvolvimento: sua conexão local
# Em produção: o Railway substitui automaticamente DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/dati_control

# ── Clerk — Autenticação ──────────────────────────────────────────────────────
# Obtenha em: https://dashboard.clerk.com → seu app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── CORS — URL do frontend em produção ───────────────────────────────────────
# Em produção: URL gerada pelo Railway (Settings → Networking → Generate Domain)
ALLOWED_ORIGIN=https://journey-dati.railway.app

# ── Resend — Envio de e-mails ─────────────────────────────────────────────────
# Opcional. Sem esta chave, os lembretes por e-mail ficam desativados.
# Obtenha em: https://resend.com
RESEND_API_KEY=re_...

# ── Gabi AI — Alertas de consumo por e-mail ───────────────────────────────────
# E-mail que vai RECEBER os alertas (destinatário) quando o gasto cruzar o threshold.
GABI_ALERT_EMAIL=seu@email.com.br
# Remetente dos alertas. Sem domínio verificado, use: Journey CRM <onboarding@resend.dev>
# Com domínio verificado no Resend, use: Journey CRM <noreply@seudominio.com>
GABI_EMAIL_FROM=Journey CRM <onboarding@resend.dev>

# ── Supabase — Storage de Anexos ─────────────────────────────────────────────
# Opcional. Sem estas chaves, o upload de anexos fica desativado.
# Obtenha em: https://supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Metabase — Signed Embedding ───────────────────────────────────────────────
# Configure após subir o serviço Metabase no Railway.
# METABASE_SECRET_KEY deve ser idêntica à MB_EMBEDDING_SECRET_KEY do serviço Metabase.
# Gere uma chave segura com: openssl rand -hex 32
METABASE_SITE_URL=https://metabase.seudominio.com
METABASE_SECRET_KEY=sua-chave-secreta-de-32-caracteres-ou-mais

# ── Google Meet — Integração com gravações automáticas ────────────────────────
# Obtenha em: Google Cloud Console → IAM & Admin → Service Accounts → Chave JSON
# Cole o conteúdo completo do JSON (em uma linha só) ou encode em base64.
# APIs necessárias: Google Meet API + Google Drive API (ambas no mesmo projeto GCP).
# ⚠️  A Service Account precisa de licença Google Workspace Business Standard (~$12/mês).
# Se ausente, a feature é completamente ignorada — nada quebra no restante do app.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"journey-meet@seu-projeto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# ID da pasta no Google Drive onde as gravações serão salvas (opcional — padrão: raiz do Drive da SA)
GOOGLE_DRIVE_RECORDINGS_FOLDER_ID=
