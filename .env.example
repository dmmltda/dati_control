# ──────────────────────────────────────────────────────────────────────────────
# Journey CRM — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# ⚠️  NUNCA commite o .env real — ele está no .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Servidor
PORT=8000
NODE_ENV=development

# ── Banco de Dados (Railway injeta automaticamente em produção) ───────────────
# Em desenvolvimento: sua conexão local
# Em produção: o Railway substitui automaticamente DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/dati_control

# ── Clerk — Autenticação ──────────────────────────────────────────────────────
# Obtenha em: https://dashboard.clerk.com → seu app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── CORS — URL do frontend em produção ───────────────────────────────────────
# Em produção: URL gerada pelo Railway (Settings → Networking → Generate Domain)
ALLOWED_ORIGIN=https://journey-dati.railway.app

# ── Resend — Envio de e-mails ─────────────────────────────────────────────────
# Opcional. Sem esta chave, os lembretes por e-mail ficam desativados.
# Obtenha em: https://resend.com
RESEND_API_KEY=re_...

# ── Supabase — Storage de Anexos ─────────────────────────────────────────────
# Opcional. Sem estas chaves, o upload de anexos fica desativado.
# Obtenha em: https://supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
