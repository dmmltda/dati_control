{
  "name": "journey-crm",
  "version": "1.0.0",
  "description": "Journey - CRM Inteligente",
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:functional": "vitest run --config vitest.functional.config.js",
    "test:functional:watch": "vitest --config vitest.functional.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:module": "playwright test --grep",
    "test:e2e:report": "playwright show-report js/tests/e2e/report",
    "test:all": "vitest run && vitest run --config vitest.functional.config.js && playwright test",
    "test:report": "vitest run --reporter=json --outputFile=test-results.json && node scripts/ingest-test-results.js --input test-results.json --type UNITÁRIO",
    "test:ingest": "node scripts/ingest-test-results.js --input test-results.json --type UNITÁRIO",
    "test:ingest:e2e": "node scripts/ingest-test-results.js --input js/tests/e2e/results/results.json --type E2E",
    "lint": "eslint js/**/*.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@vitest/coverage-v8": "^1.3.0",
    "@vitest/ui": "^1.3.0",
    "jsdom": "^24.0.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  }
}
