  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@vitest/coverage-v8": "^1.3.0",
    "vitest": "^1.3.0",
    "jsdom": "^24.0.0",
    "@vitest/ui": "^1.3.0"
  }
}